# =============================================================================
#  server_docker_compose/.env.example
#
#  Template à copier vers .env sur le VPS et remplir avec les vraies valeurs.
#  Ne jamais committer le .env réel (il contient les secrets de production).
#
#  Usage :
#    cp .env.example .env
#    nano .env   # remplir toutes les valeurs "change_me"
# =============================================================================

# ── Environnement ─────────────────────────────────────────────────────────────
# Le VPS héberge uniquement l'environnement de test (branche git : test).
# Le pipeline CD vérifie que cette valeur vaut "test" avant de déployer.
ENVIRONMENT=test

# ── Images DockerHub ──────────────────────────────────────────────────────────
# test : fredissimo/mymemomaster_test_api:latest
IMAGE_API=fredissimo/mymemomaster_test_api:latest
IMAGE_FRONT=fredissimo/mymemomaster_test_front:latest

# ── API ───────────────────────────────────────────────────────────────────────
API_PORT=3000
AUTH_JWT_SECRET=change_me
AUTH_JWT_EXPIRES_IN=1d
API_BYPASS_AUTH=false
DB_SYNC_MAX_RETRIES=5
DB_SYNC_RETRY_DELAY=5000
ADMIN_SEED_PASSWORD=change_me

# ── Email (nodemailer / SMTP) ─────────────────────────────────────────────────
# SMTP_SECURE=true → port 465 SSL  |  false → port 587 STARTTLS (recommandé Hostinger)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=change_me@example.com
SMTP_PASS=change_me
EMAIL_FROM=noreply@example.com

# ── Base de données PostgreSQL ────────────────────────────────────────────────
PG_USER=postgres
PG_PASS=change_me
PG_DB=mymemomasterdb
PG_PORT=5432
PG_POOL_MAX=10
PG_POOL_MIN=2
PG_POOL_ACQUIRE=30000
PG_POOL_IDLE=10000

# ── PgAdmin ───────────────────────────────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change_me

# ── Domaines VPS (test) ───────────────────────────────────────────────────────
FRONT_DOMAIN=test.my-memo-master.com
API_DOMAIN=test-api.my-memo-master.com
PGADMIN_DOMAIN=test-pgadmin.my-memo-master.com

# ── URL publique API ──────────────────────────────────────────────────────────
API_PUBLIC_URL=https://test-api.my-memo-master.com

# ── Front — config runtime injectée dans window.__APP_CONFIG__ ───────────────
VITE_FRONT_URL=https://test.my-memo-master.com
VITE_API_URL=https://test-api.my-memo-master.com/api/v1

# ── Limites de ressources Docker ─────────────────────────────────────────────
# Adapter selon la capacité du VPS (valeurs ci-dessous = défauts raisonnables)
POSTGRES_LIMIT_CPUS=0.50
POSTGRES_LIMIT_MEMORY=1024M
POSTGRES_RESERVE_CPUS=0.25
POSTGRES_RESERVE_MEMORY=256M

PGADMIN_LIMIT_CPUS=0.25
PGADMIN_LIMIT_MEMORY=256M
PGADMIN_RESERVE_CPUS=0.10
PGADMIN_RESERVE_MEMORY=64M

API_LIMIT_CPUS=0.50
API_LIMIT_MEMORY=512M
API_RESERVE_CPUS=0.25
API_RESERVE_MEMORY=128M

FRONT_LIMIT_CPUS=0.25
FRONT_LIMIT_MEMORY=256M
FRONT_RESERVE_CPUS=0.10
FRONT_RESERVE_MEMORY=64M

# ── Redis (BullMQ — rappels et notifications) ─────────────────────────────────
# REDIS_PASS : laisser vide pour désactiver l'authentification Redis
REDIS_PASS=
REDIS_PORT=6379
REDIS_LIMIT_CPUS=0.25
REDIS_LIMIT_MEMORY=128M
REDIS_RESERVE_CPUS=0.10
REDIS_RESERVE_MEMORY=32M

# =============================================================================
#  Secret Cloudflare API Token — cert-manager DNS01
#
#  Ce fichier est un template. Ne jamais mettre de vraie valeur ici.
#  Le fichier réel (cloudflare-secret.yml) est dans .gitignore.
#
#  Setup :
#    1. Copier ce fichier :
#         cp k8s/cert-manager/cloudflare-secret.yml.example \
#            k8s/cert-manager/cloudflare-secret.yml
#
#    2. Créer un API Token Cloudflare avec la permission :
#         Zone → DNS → Edit  (+ Zone → Zone → Read si nécessaire)
#
#    3. Encoder le token en base64 :
#         echo -n "TON_TOKEN_CLOUDFLARE" | base64
#
#    4. Remplacer CHANGE_ME_BASE64_ENCODED_TOKEN par le résultat
#
#    5. Appliquer dans l'ordre :
#         kubectl apply -f k8s/cert-manager/cloudflare-secret.yml
#         kubectl apply -f k8s/cert-manager/cluster-issuer-cloudflare.yml
# =============================================================================

apiVersion: v1
kind: Secret
metadata:
  name: cloudflare-api-token
  namespace: cert-manager
type: Opaque
data:
  api-token: CHANGE_ME_BASE64_ENCODED_TOKEN

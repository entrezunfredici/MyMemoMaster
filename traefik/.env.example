# =============================================================================
#  Traefik — variables d'environnement
#  Copier ce fichier en .env et renseigner les valeurs
# =============================================================================

# ── Let's Encrypt ─────────────────────────────────────────────────────────────
# Email pour les notifications d'expiration de certificat
LETSENCRYPT_EMAIL=change_me@example.com

# ── Dashboard Traefik (optionnel) ─────────────────────────────────────────────
# Mettre à true uniquement en environnement de confiance
TRAEFIK_DASHBOARD=false
TRAEFIK_DASHBOARD_DOMAIN=traefik.yourdomain.com
# Hash bcrypt de l'identifiant admin:password
# Générer avec : echo $(htpasswd -nB admin) | sed -e s/\\$/\\$\\$/g
TRAEFIK_DASHBOARD_AUTH=admin:$$2y$$10$$change_me_generate_a_real_hash

# ── Logs ──────────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARN | ERROR
TRAEFIK_LOG_LEVEL=INFO

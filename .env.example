# =============================================================================
#  .env.example — Template à copier vers .env.dev / .env.test / .env.prod
#  Ne jamais committer les vrais fichiers .env.* (secrets inclus)
# =============================================================================

# ── Profil actif ──────────────────────────────────────────────────────────────
# Valeurs possibles : dev | test | prod
COMPOSE_PROFILES=dev
ENVIRONMENT=dev

# ── Images Docker ─────────────────────────────────────────────────────────────
# dev  : IMAGE_FRONT=my_memo_master_front:local
# test : IMAGE_FRONT=fredissimo/my_memo_master_front:latest
DOCKERHUB_USERNAME=fredissimo
IMAGE_TAG=latest
IMAGE_FRONT=my_memo_master_front:local
IMAGE_API=my_memo_master_api:local

# ── Front — variables injectées au build Vite (dev) ──────────────────────────
# En test/prod ces vars alimentent window.__APP_CONFIG__ au runtime
VITE_APP_SHORT_NAME=MMM
VITE_APP_NAME=MyMemoMaster
VITE_APP_COMPANY_NAME=MyMemoMaster
VITE_APP_AUTHOR_NAME="MyMemoMaster's team"
VITE_APP_DESCRIPTION=""
VITE_APP_THEME_COLOR=#ffffff
VITE_APP_BG_COLOR=#000000
VITE_PORT=5173
VITE_FRONT_URL=http://localhost
VITE_API_URL=http://localhost/api/v1

# ── Backend ───────────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=3000
# URL publique du frontend — utilisée pour construire le lien de vérification email
APP_FRONT_URL=http://localhost
AUTH_JWT_SECRET=change_me
# Avec refresh token actif, préférer une durée courte (15m recommandé)
AUTH_JWT_EXPIRES_IN=15m
AUTH_REFRESH_TOKEN_EXPIRES_DAYS=7
API_BYPASS_AUTH=false
# SMTP_SECURE=true  → port 465 SSL  |  false → port 587 STARTTLS (recommandé Hostinger)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=support@my-memo-master.com
SMTP_PASS=change_me
EMAIL_FROM=support@my-memo-master.com
DB_SYNC_MAX_RETRIES=3
DB_SYNC_RETRY_DELAY=3000
ADMIN_SEED_PASSWORD=change_me

# ── Base de données ───────────────────────────────────────────────────────────
PG_USER=postgres
PG_HOST=postgres
PG_PASS=change_me
PG_DB=mymemomasterdb
PG_PORT=5432
PG_POOL_MAX=10
PG_POOL_MIN=2
PG_POOL_ACQUIRE=30000
PG_POOL_IDLE=10000

# ── PGAdmin ───────────────────────────────────────────────────────────────────
PGADMIN_PORT=5051
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change_me

# ── Limites de ressources Docker ─────────────────────────────────────────
# Format cpus : fraction de CPU (0.50 = 50 % d'un cœur)
# Format memory : M (mégaoctets) ou G (gigaoctets)
# Les valeurs ci-dessous sont les défauts inscrits dans docker-compose.yml.
# Surcharger ici pour adapter à la capacité de la machine / du VPS.

# postgres
POSTGRES_LIMIT_CPUS=0.50
POSTGRES_LIMIT_MEMORY=1024M
POSTGRES_RESERVE_CPUS=0.25
POSTGRES_RESERVE_MEMORY=256M

# traefik (dev uniquement)
TRAEFIK_LIMIT_CPUS=0.25
TRAEFIK_LIMIT_MEMORY=256M
TRAEFIK_RESERVE_CPUS=0.10
TRAEFIK_RESERVE_MEMORY=64M

# pgadmin
PGADMIN_LIMIT_CPUS=0.25
PGADMIN_LIMIT_MEMORY=256M
PGADMIN_RESERVE_CPUS=0.10
PGADMIN_RESERVE_MEMORY=64M

# api / api_server
API_LIMIT_CPUS=0.50
API_LIMIT_MEMORY=512M
API_RESERVE_CPUS=0.25
API_RESERVE_MEMORY=128M

# front / front_server
FRONT_LIMIT_CPUS=0.25
FRONT_LIMIT_MEMORY=256M
FRONT_RESERVE_CPUS=0.10
FRONT_RESERVE_MEMORY=64M

# ── Stockage fichiers (S3 compatible) ─────────────────────────────────────────
# Fonctionne avec AWS S3, Scaleway Object Storage, Backblaze B2, MinIO, Cloudflare R2...
# S3_ENDPOINT : laisser vide pour AWS S3 standard, sinon mettre l'URL du fournisseur
# S3_FORCE_PATH_STYLE : true pour MinIO/self-hosted, false pour AWS et la plupart des fournisseurs
S3_ENDPOINT=
S3_REGION=eu-west-3
S3_BUCKET=my-memo-master
S3_ACCESS_KEY=change_me
S3_SECRET_KEY=change_me
S3_PUBLIC_URL=https://my-bucket.s3.eu-west-3.amazonaws.com
S3_FORCE_PATH_STYLE=false

# ── URL publique API (utilisée par Swagger UI pour générer les server URLs) ───
# dev  : http://localhost  (Traefik local)
# prod : https://api.my-memo-master.com
API_PUBLIC_URL=http://localhost

# ── Domaines ──────────────────────────────────────────────────────────────────
# dev  : localhost
# test : tests.my-memo-master.com
# prod : my-memo-master.com
FRONT_DOMAIN=localhost
API_DOMAIN=localhost
PGADMIN_DOMAIN=localhost
APP_PUBLIC_URL=localhost

# ── Redis (BullMQ — rappels et notifications) ─────────────────────────────────
# En Docker, REDIS_HOST = nom du service (redis). En local sans Docker : 127.0.0.1
REDIS_HOST=redis
REDIS_PORT=6379
# REDIS_PASS=                 # laisser vide pour désactiver l'authentification Redis
# Limites ressources Docker Redis
REDIS_LIMIT_CPUS=0.25
REDIS_LIMIT_MEMORY=128M
REDIS_RESERVE_CPUS=0.10
REDIS_RESERVE_MEMORY=32M

# ── Sécurité (CORS / Rate limiting) ──────────────────────────────────────────
# Origines autorisées pour CORS (virgule pour plusieurs, ex: http://a.com,http://b.com)
# Si absent, VITE_FRONT_URL est utilisé comme fallback
CORS_ORIGIN=http://localhost
# Limites rate limiting — valeurs par défaut si absent (suffisant pour MVP)
# AUTH_RATE_MAX=5            # tentatives max login/verify/forgot/reset (fenêtre 15 min)
# AUTH_RATE_WINDOW_MS=900000
# REGISTER_RATE_MAX=10       # créations de compte max par heure
# REGISTER_RATE_WINDOW_MS=3600000
# API_RATE_MAX=200           # requêtes max toutes routes /api/v1 confondues (fenêtre 15 min)
# API_RATE_WINDOW_MS=900000
